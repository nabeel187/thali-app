{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/estimate.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/estimate", "dest": "/api/estimate.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
