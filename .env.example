# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Any vision-capable model on OpenRouter works. Defaults to openai/gpt-4o-mini if unset.
# Other good options: google/gemini-2.0-flash-001, anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional — shown to OpenRouter for analytics/rate-limit attribution, not required.
APP_URL=https://your-deployed-url.example.com

# Optional — used by server.js when running locally or on Render.
PORT=3000
